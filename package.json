{
	"name": "build-and-run",
	"displayName": "Build and Run",
	"description": "Build and Run your code with ease. Pass input from source comments.",
	"version": "3.0.0",
	"publisher": "glelesius",
	"bugs": {
		"url": "https://github.com/gediminasel/build-and-run-vs/issues",
		"email": "dev@lelesius.eu"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/gediminasel/build-and-run-vs.git"
	},
	"license": "GNU GENERAL PUBLIC LICENSE Version 3. See license in LICENSE.txt",
	"engines": {
		"vscode": "^1.34.0"
	},
	"categories": [
		"Testing",
		"Other"
	],
	"activationEvents": [
		"onStartupFinished"
	],
	"main": "./out/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "build-and-run:build_run",
				"title": "B&R: Build and Run with input"
			},
			{
				"command": "build-and-run:build",
				"title": "B&R: Build"
			},
			{
				"command": "build-and-run:build_debug",
				"title": "B&R: Build and Debug with input"
			},
			{
				"command": "build-and-run:kill",
				"title": "B&R: Kill running program"
			},
			{
				"command": "build-and-run:format",
				"title": "B&R: Format"
			},
			{
				"command": "build-and-run:cleanup_temp",
				"title": "B&R: Cleanup temp files"
			}
		],
		"configuration": {
			"title": "Build and Run",
			"properties": {
				"buildAndRun.outputFlushPeriod": {
					"type": [
						"number",
						"null"
					],
					"description": "How long to wait between output flushes in ms. Too small values will trigger VSCode internal buffering.",
					"default": 500,
					"minimum": 100
				},
				"buildAndRun.onlyOneRunning": {
					"type": "boolean",
					"description": "If enabled, currently running program will be killed before compiling and running a new one.",
					"default": true
				},
				"buildAndRun.clearBeforeRunning": {
					"type": "boolean",
					"description": "If enabled, will clear the output of previous program before running compiling a new one.",
					"default": true
				},
				"buildAndRun.showResultInline": {
					"type": "boolean",
					"description": "If enabled, will show build results inline using Tests API in addition to Output panel.",
					"default": true
				},
				"buildAndRun.languageConfigs": {
					"type": "object",
					"description": "Build and Run configuration.",
					"additionalProperties": {
						"type": "object",
						"description": "Build and Run language configuration.",
						"properties": {
							"build": {
								"type": "array",
								"description": "Build command with arguments",
								"items": {
									"type": "string"
								}
							},
							"run": {
								"type": "array",
								"description": "Run command with arguments",
								"items": {
									"type": "string"
								}
							},
							"debugBuild": {
								"type": "array",
								"description": "Debug build command",
								"items": {
									"type": "string"
								}
							},
							"debugRun": {
								"type": "array",
								"description": "Debug run command with arguments",
								"items": {
									"type": "string"
								}
							},
							"format": {
								"type": "array",
								"description": "Format command with arguments",
								"items": {
									"type": "string"
								}
							},
							"formatStdin": {
								"type": "boolean",
								"description": "Whether to pass input file contents to the format command via stdin",
								"default": true
							},
							"inputBegin": {
								"type": "string",
								"description": "Input comment begin symbols"
							},
							"inputEnd": {
								"type": "string",
								"description": "Input comment end symbols"
							},
							"outputBegin": {
								"type": "string",
								"description": "Output comment begin symbols"
							},
							"outputEnd": {
								"type": "string",
								"description": "Output comment end symbols"
							},
							"ext": {
								"type": "string",
								"description": "File extension for temporary files when running unsaved buffers"
							}
						}
					}
				}
			}
		}
	},
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"package": "vsce package",
		"publish": "vsce publish",
		"compile": "tsc -p ./",
		"lint": "eslint . --ext .ts,.tsx",
		"watch": "tsc -watch -p ./"
	},
	"devDependencies": {
		"@types/node": "^18.0.5",
		"@types/vscode": "^1.34.0",
		"@typescript-eslint/eslint-plugin": "^5.30.6",
		"@typescript-eslint/parser": "^5.30.6",
		"eslint": "^8.19.0",
		"path": "0.12.7",
		"typescript": "^4.7.4",
		"@vscode/vsce": "^3.2.1"
	}
}
